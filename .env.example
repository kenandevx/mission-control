# Mission Control Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Database
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# API Basic Auth (for /api/* routes)
API_USER=your-username
API_PASS=your-strong-password

# OpenClaw Gateway (for task-worker to communicate with main agent)
# In dev, this points to the host gateway; adjust if using remote gateway
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=  # optional; leave empty if gateway has no token

# Optional: OpenAI API key for memory embeddings (if using memory-qdrant)
# OPENAI_API_KEY=sk-...