# Mission Control Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Database
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# API Basic Auth (for /api/* routes)
API_USER=your-username
API_PASS=your-strong-password

# OpenClaw gateway config is auto-discovered from ~/.openclaw/openclaw.json.
# Do NOT set OPENCLAW_GATEWAY_URL or OPENCLAW_GATEWAY_TOKEN here —
# they override CLI auto-discovery and cause auth failures in OpenClaw 4.x.
# If you need to override, set them only after verifying gateway pairing works.

# Optional: OpenAI API key for memory embeddings (if using memory-qdrant)
# OPENAI_API_KEY=sk-...

# Agenda services now run in strict schema mode.
# Ensure db/schema + migrations are applied before starting workers/scheduler.