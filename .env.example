# Mission Control Environment Configuration
# Copy this file to .env.local and fill in your values.
# Never commit .env or .env.local to version control.

# ── Database ──────────────────────────────���─────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
DATABASE_URL=postgresql://openclaw:change-me-to-a-strong-random-password@localhost:5432/mission_control
OPENCLAW_DATABASE_URL=postgresql://openclaw:change-me-to-a-strong-random-password@localhost:5432/mission_control

# ── Microsoft Entra ID (login authentication) ───────────────
# Create an App Registration in the Azure portal:
#   1. portal.azure.com → Azure Active Directory → App registrations → New registration
#   2. Authentication → Add redirect URI:
#        http://localhost:3000/api/auth/callback/microsoft-entra-id
#   3. Authentication → enable "Allow public client flows"  (required — no client secret used)
#   4. Copy the Application (client) ID and Directory (tenant) ID below
AZURE_AD_CLIENT_ID=your-application-client-id
AZURE_AD_TENANT_ID=your-directory-tenant-id

# ── NextAuth session signing key ─────────────────────────────
# Generate with: openssl rand -base64 32
# Never share or commit this value.
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# The public URL Mission Control is served from.
# Change this if you access it from a domain instead of localhost.
NEXTAUTH_URL=http://localhost:3000

# ── OpenClaw gateway ─────────────────────────────────────────
# Gateway config is auto-discovered from ~/.openclaw/openclaw.json.
# Do NOT set OPENCLAW_GATEWAY_URL or OPENCLAW_GATEWAY_TOKEN here —
# they override CLI auto-discovery and cause auth failures in OpenClaw 4.x.

# ── Optional ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...   # for memory embeddings (memory-qdrant)
