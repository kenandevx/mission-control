{
  "name": "dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "docker compose up -d db db-init bridge-logger task-worker gateway-sync && next dev",
    "dev:stop": "docker compose stop db db-init bridge-logger task-worker gateway-sync",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "node scripts/db-setup.mjs migrate",
    "db:seed": "node scripts/db-setup.mjs seed",
    "db:setup": "node scripts/db-setup.mjs setup",
    "db:reset": "node scripts/db-setup.mjs reset",
    "bot:setup": "node scripts/openclaw-bot-setup.mjs",
    "bridge:logger": "node scripts/bridge-logger.mjs",
    "bridge:logger:check": "node --check scripts/bridge-logger.mjs",
    "worker:tasks": "node scripts/task-worker.mjs",
    "worker:tasks:check": "node --check scripts/task-worker.mjs",
    "test:worker": "node --test lib/tasks/worker-core.test.mjs",
    "logs:repair-attribution": "node scripts/repair-agent-log-attribution.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tabler/icons-react": "^3.38.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postgres": "^3.4.8",
    "sass": "^1.93.3",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
